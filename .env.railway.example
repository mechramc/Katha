# Railway Environment Variables — KATHA
# Copy relevant values into Railway service settings.

# === Vault Service ===
VAULT_PORT=3001
VAULT_DB_PATH=/data/katha.db
# Paste full PEM content (including BEGIN/END lines) as env var value:
JWT_PRIVATE_KEY=<paste PEM content>
JWT_PUBLIC_KEY=<paste PEM content>

# === Engine Service ===
ENGINE_PORT=3002
ANTHROPIC_API_KEY=<your key>
VAULT_URL=https://katha-vault.up.railway.app
CLAUDE_MODEL=claude-sonnet-4-6
CORS_ORIGIN=https://murailabs.com
